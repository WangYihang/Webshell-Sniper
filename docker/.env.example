# Copy this file to `docker/.env` to override the base images used by
# docker-compose. Useful when Docker Hub's anonymous pull rate limit blocks
# you — the AWS ECR public mirror of Docker Hub official images has no such
# limit:
#
#   cp docker/.env.example docker/.env
#
# PHP_IMAGE=public.ecr.aws/docker/library/php:8.3-apache
# MYSQL_IMAGE=public.ecr.aws/docker/library/mysql:8.4
# POSTGRES_IMAGE=public.ecr.aws/docker/library/postgres:16
# TOMCAT_IMAGE=public.ecr.aws/docker/library/tomcat:10.1-jre17
